# ─── Database (Neon Postgres, serverless driver) ───────────────────────────────
# Create a free project at https://neon.tech and paste the pooled connection string.
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI Advisor (optional, local-first) ────────────────────────────────────────
# Install Ollama (https://ollama.com) and pull a model: `ollama pull llama3.2`
# When unset/unreachable the advisor falls back to a deterministic engine.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
